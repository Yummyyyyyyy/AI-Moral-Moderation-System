# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Required when MMS_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-replace-me

# Optional overrides (defaults shown):
# MMS_LLM_PROVIDER=dummy
# MMS_LLM_MODEL=gpt-4o-mini
# MMS_C1_IMPL=dummy
# MMS_C2_IMPL=dummy
# MMS_RAG_IMPL=dummy
# MMS_POLISHER_IMPL=dummy
# MMS_POLISHER_URL=               # leave empty to auto-fetch from Drive
# MMS_POLISHER_TIMEOUT=15
# MMS_AUTO_PUBLISH=0              # 1 = bypass moderator queue (demo only)

# Model artifact overrides (only set if model files live outside the defaults):
# MMS_BINARY_MODEL_DIR=app/classifier/model_assets
# MMS_TYPED_MODEL_DIR=models/multitask_roberta_base_v1
# MMS_TYPED_DEVICE=                # auto-detected; set to cpu/cuda/mps to force