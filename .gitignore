# Python
__pycache__/
*.py[cod]
.venv/
env/
venv/
*.db
*.sqlite3
.pytest_cache/
pytest-cache-files-*/
.DS_Store

# Secrets — never commit
.env

# Node
node_modules/
dist/
.vite/
*.tsbuildinfo

# TypeScript build output emitted next to source
MMS_front/src/**/*.js

# logs / temp
*.log
.tmp

# Model artifacts (large binary files, not for version control).
# All ML weights / FAISS indexes live under MMS_back/models/<name>/.
# We keep empty per-module dirs in version control via .gitkeep so a fresh
# clone has the layout; the artifacts themselves are downloaded out of band.
MMS_back/models/**
!MMS_back/models/
!MMS_back/models/*/
!MMS_back/models/.gitkeep
!MMS_back/models/*/.gitkeep